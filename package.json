{
  "name": "@gittan/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "gittan": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:binary": "bash scripts/build-all.sh",
    "publish:binary": "bash scripts/publish.sh",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gittan.eu/bloomer/gittan-cli.git"
  },
  "dependencies": {
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1"
}
